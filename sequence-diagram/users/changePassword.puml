@startuml Change Password (PUT)

header RealHaus Sequence Diagram - Users Controller
footer Page %page% of %lastpage%
title "Change Password (PUT /api/v1/users/me/password)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:users" as routerUsers
participant "<<middleware>>\n:auth" as middlewareAuth
participant "<<controllers>>\n:users" as controllersUsers
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDB

client->server ++:req.put('/api/v1/users/me/password')
server->routerUsers ++:app.use('/api/v1/users',users)
routerUsers -> middlewareAuth ++:protect()

alt No token or token is null
    middlewareAuth->client --:res.status(401).json({success:false,\nmessage:'Not authorize to access this route'})
else Valid token
    middlewareAuth->middlewareAuth :jwt.verify(token,JWT_SECRET)
    middlewareAuth->modelUser ++:User.findById(decoded.id)
    modelUser->UsersDB ++: findById()
    UsersDB-->modelUser --: user
    middlewareAuth<--modelUser --:req.user = user
    middlewareAuth -> controllersUsers ++:next() -> changePassword()

    alt Missing currentPassword or newPassword
        controllersUsers->client --:res.status(400).json({success:false,\nmessage:'Please provide current password and new password'})
    else Has both passwords
        controllersUsers->modelUser ++:User.findById(req.user.id)\n.select('+password')
        modelUser->UsersDB ++: findById() with password
        UsersDB-->modelUser --: user with password
        controllersUsers<--modelUser --:user

        controllersUsers->modelUser ++:user.matchPassword(currentPassword)
        modelUser-->controllersUsers --:isMatch

        alt Current password incorrect
            controllersUsers->client --:res.status(401).json({success:false,\nmessage:'Current password is incorrect'})
        else Password matches
            controllersUsers->controllersUsers :user.password = newPassword

            controllersUsers->modelUser ++:user.save()
            modelUser->UsersDB ++: save() (password hashed by pre-save hook)
            UsersDB-->modelUser --: saved
            controllersUsers<--modelUser --:saved

            controllersUsers->client --:res.status(200).json({success:true,\nmessage:'Password updated successfully'})
        end
    end
end

@enduml
