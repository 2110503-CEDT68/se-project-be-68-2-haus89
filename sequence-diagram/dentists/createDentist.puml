@startuml Create Dentist (POST)

header RealHaus Sequence Diagram - Dentists Controller
footer Page %page% of %lastpage%
title "Create Dentist (POST /api/v1/dentists) - Admin Only"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:dentists" as routerDentists
participant "<<middleware>>\n:auth" as middlewareAuth
participant "<<controllers>>\n:dentists" as controllersDentists
participant "<<model>>\n:User" as modelUser
participant "<<model>>\n:Dentist" as modelDentist
database "<<MongoDB>>\n:users" as UsersDB
database "<<MongoDB>>\n:dentists" as DentistsDB

client->server ++:req.post('/api/v1/dentists')
server->routerDentists ++:app.use('/api/v1/dentists',dentists)
routerDentists -> middlewareAuth ++:protect()

alt No token or token is null
    middlewareAuth->client --:res.status(401).json({success:false,\nmessage:'Not authorize to access this route'})
else Valid token
    middlewareAuth->middlewareAuth :jwt.verify(token,JWT_SECRET)
    middlewareAuth->modelUser ++:User.findById(decoded.id)
    modelUser->UsersDB ++: findById()
    UsersDB-->modelUser --: user
    middlewareAuth<--modelUser --:req.user = user
    middlewareAuth -> middlewareAuth :authorize('admin')

    alt User role is not admin
        middlewareAuth->client --:res.status(403).json({success:false,\nmessage:'User role is not authorized to access this route'})
    else User is admin
        middlewareAuth -> controllersDentists ++:next() -> createDentist()

        controllersDentists->modelDentist ++:Dentist.create(req.body)
        modelDentist->DentistsDB ++: DentistSchema
        DentistsDB-->modelDentist --: dentist
        controllersDentists<--modelDentist --:dentist

        controllersDentists->client --:res.status(201).json({success:true,data:dentist})
    end
end

@enduml
