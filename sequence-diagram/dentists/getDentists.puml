@startuml Get All Dentists (GET)

header RealHaus Sequence Diagram - Dentists Controller
footer Page %page% of %lastpage%
title "Get All Dentists (GET /api/v1/dentists)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:dentists" as routerDentists
participant "<<controllers>>\n:dentists" as controllersDentists
participant "<<model>>\n:Dentist" as modelDentist
database "<<MongoDB>>\n:dentists" as DentistsDB

client->server ++:req.get('/api/v1/dentists?select=...&sort=...&page=...&limit=...')
server->routerDentists ++:app.use('/api/v1/dentists',dentists)
routerDentists -> controllersDentists ++:getDentists()

controllersDentists->controllersDentists :Parse query params\n(select, sort, page, limit, filters)
controllersDentists->controllersDentists :Build query with operators\n($gt, $gte, $lt, $lte, $in)

controllersDentists->modelDentist ++:Dentist.countDocuments()
modelDentist->DentistsDB ++: countDocuments()
DentistsDB-->modelDentist --: total
controllersDentists<--modelDentist --:total

controllersDentists->modelDentist ++:Dentist.find(filters)\n.select(fields).sort(sortBy)\n.skip(startIndex).limit(limit)
modelDentist->DentistsDB ++: find() with pagination
DentistsDB-->modelDentist --: dentists
controllersDentists<--modelDentist --:dentists

controllersDentists->controllersDentists :Build pagination object\n(next/prev page)

controllersDentists->client --:res.status(200).json({success:true,count,pagination,data:dentists})

@enduml
