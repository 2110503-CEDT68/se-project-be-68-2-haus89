@startuml Get Me (GET)

header RealHaus Sequence Diagram - Auth Controller
footer Page %page% of %lastpage%
title "Get Me (GET /api/v1/auth/me)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<middleware>>\n:auth" as middlewareAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client->server ++:req.get('/api/v1/auth/me')
server->routerAuth ++:app.use('/api/v1/auth',auth)
routerAuth -> middlewareAuth ++:protect()

alt No token or token is null
    middlewareAuth->client --:res.status(401).json({success:false,\nmessage:'Not authorize to access this route'})
else Valid token
    middlewareAuth->middlewareAuth :jwt.verify(token,JWT_SECRET)
    middlewareAuth->modelUser ++:User.findById(decoded.id)
    modelUser->UsersDatabase ++: findById()
    UsersDatabase-->modelUser --: user
    middlewareAuth<--modelUser --:req.user = user
    middlewareAuth -> controllersAuth ++:next() -> getMe()
    controllersAuth->modelUser ++:User.findById(req.user.id).populate('booking')
    modelUser->UsersDatabase ++: findById() + populate
    UsersDatabase-->modelUser --: user with booking
    controllersAuth<--modelUser --:user
    controllersAuth->client --:res.status(200).json({success:true,data:user})
end

@enduml
