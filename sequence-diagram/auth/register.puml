@startuml Register (POST)

header RealHaus Sequence Diagram - Auth Controller
footer Page %page% of %lastpage%
title "Register (POST /api/v1/auth/register)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as UsersDatabase

client->server ++:req.post('/api/v1/auth/register')
server->routerAuth ++:app.use('/api/v1/auth',auth)
routerAuth -> controllersAuth ++:register()
controllersAuth->modelUser ++:User.create({name,email,phone,password,role})
modelUser ->UsersDatabase ++: UserSchema

alt Success
    UsersDatabase --> modelUser --: user
    controllersAuth <-- modelUser --:user
    controllersAuth->controllersAuth :user.getSignedJwtToken()
    controllersAuth->client --:res.status(200).cookie('token',token).json({success:true,token})
else Validation/Duplicate Error
    UsersDatabase --> modelUser --: Error
    controllersAuth <-- modelUser --:Error thrown
    controllersAuth->client --:res.status(400).json({success:false})
end

@enduml
