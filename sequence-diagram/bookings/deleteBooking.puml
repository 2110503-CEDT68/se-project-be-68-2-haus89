@startuml Delete Booking (DELETE)

header Dentist Booking System - Bookings
footer Page %page% of %lastpage%
title "Delete Booking (DELETE)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:bookings" as routerBookings
participant "<<controllers>>\n:bookings" as controllersBookings
participant "<<model>>\n:Booking" as modelBooking
participant "<<model>>\n:User" as modelUser
participant "<<model>>\n:Dentist" as modelDentist
database "<<MongoDB>>\n:bookings" as BookingsDatabase
database "<<MongoDB>>\n:users" as UsersDatabase
database "<<MongoDB>>\n:dentists" as DentistsDatabase

client->server ++:req.delete('/api/v1/bookings/:id')
server->routerBookings ++:app.use('/api/v1/bookings',bookings)
routerBookings -> controllersBookings ++:deleteBooking()
controllersBookings->modelBooking ++:findById(req.params.id)
modelBooking ->BookingsDatabase ++: find booking
BookingsDatabase --> modelBooking --: booking
controllersBookings <-- modelBooking --:booking

alt booking not found
    controllersBookings->client --:error {success: false, message: 'Booking not found'}
else booking found
    controllersBookings->controllersBookings:check authorization
    alt not authorized
        controllersBookings->client --:error {success: false, message: 'Not authorized'}
    else authorized
        controllersBookings->modelUser ++:findByIdAndUpdate(booking.user, {booking: null})
        modelUser ->UsersDatabase ++: remove booking reference
        UsersDatabase --> modelUser --: updated
        controllersBookings <-- modelUser --:updated
        
        controllersBookings->modelDentist ++:findOneAndUpdate(..., {$set: {'availableSlots.$.isBooked': false}})
        modelDentist ->DentistsDatabase ++: release slot
        DentistsDatabase --> modelDentist --: updated
        controllersBookings <-- modelDentist --:updated
        
        controllersBookings->modelBooking ++:deleteOne({_id: req.params.id})
        modelBooking ->BookingsDatabase ++: delete booking
        BookingsDatabase --> modelBooking --: deleted
        controllersBookings <-- modelBooking --:deleted
        
        controllersBookings->client --:response {success: true, data: {}}
    end
end

@enduml
