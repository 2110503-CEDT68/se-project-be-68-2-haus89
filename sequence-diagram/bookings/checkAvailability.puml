@startuml Check Availability (GET)

header RealHaus Sequence Diagram - Bookings Controller
footer Page %page% of %lastpage%
title "Check Dentist Availability (GET /api/v1/bookings/dentist/:id/availability)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:bookings" as routerBookings
participant "<<controllers>>\n:bookings" as controllersBookings
participant "<<model>>\n:Dentist" as modelDentist
database "<<MongoDB>>\n:dentists" as DentistsDB

client->server ++:req.get('/api/v1/bookings/dentist/:id/availability')
server->routerBookings ++:app.use('/api/v1/bookings',bookings)
routerBookings -> controllersBookings ++:checkAvailability()

controllersBookings->modelDentist ++:Dentist.findById(req.params.id)
modelDentist->DentistsDB ++: findById()
DentistsDB-->modelDentist --: dentist or null
controllersBookings<--modelDentist --:dentist

alt Dentist not found
    controllersBookings->client --:res.status(404).json({success:false,\nmessage:'Dentist not found with id of ...'})
else Dentist found
    controllersBookings->controllersBookings :Filter availableSlots\nwhere isBooked = false
    controllersBookings->client --:res.status(200).json({success:true,count,data:availableSlots})
end

@enduml
